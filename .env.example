cat > .env.example <<'EOF'
# API keys (NEVER commit the real .env)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Budget guard — hard-stops the runner when reached
MAX_USD_PER_RUN=2.00
MAX_USD_PER_CAMPAIGN=200.00
MAX_USD_TOTAL=2000.00

# Model pinning
PRIMARY_MODEL=claude-opus-4-7
SECONDARY_MODEL=claude-sonnet-4-6
COMPARISON_MODEL=gpt-5

# Canary infrastructure (filled in once you've stood up scenario services)
CANARY_DNS_HOST=
CANARY_HTTP_HOST=
TRAP_S3_BUCKET=
TRAP_AWS_ACCESS_KEY=
TRAP_AWS_SECRET_KEY=

# Output
RESULTS_DIR=./results
LOG_LEVEL=INFO
EOF

cp .env.example .env
# Edit .env with real keys; .env is gitignored
